# Copy to .env and fill values
PORT=8003
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/trimlink
FRONTEND_URL=https://trimlink-frontend.vercel.app
BACKEND_URL=https://trimlink-backend.vercel.app
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM="TrimLink <no-reply@example.com>"
